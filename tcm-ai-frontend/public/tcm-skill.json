{
  "$schema": "https://raw.githubusercontent.com/anthropics/openclaw/main/schemas/skill.json",
  "name": "tcm-automation",
  "version": "1.0.0",
  "description": "中医智能平台 (TCM-AI) 本地自动化能力扩展",
  "author": "TCM-AI-Platform",
  "license": "MIT",
  
  "homepage": "https://github.com/your-org/tcm-ai-platform",
  
  "keywords": [
    "tcm",
    "chinese-medicine",
    "healthcare",
    "hospital-booking",
    "medication-reminder",
    "automation"
  ],
  
  "main": "index.js",
  
  "engines": {
    "node": ">=18.0.0",
    "openclaw": ">=0.8.0"
  },
  
  "dependencies": {
    "playwright": "^1.40.0"
  },
  
  "permissions": [
    "browser",
    "filesystem",
    "calendar",
    "camera",
    "notifications"
  ],
  
  "tools": [
    {
      "name": "book_hospital_appointment",
      "description": "使用本地浏览器在指定医院网站自动挂号。会打开可见浏览器窗口，用户可监督全过程。",
      "riskLevel": "HIGH",
      "requiresConfirmation": true,
      "parameters": {
        "type": "object",
        "required": ["department", "date"],
        "properties": {
          "hospitalUrl": {
            "type": "string",
            "description": "医院挂号网站 URL",
            "default": "https://www.cs4hospital.cn/"
          },
          "department": {
            "type": "string",
            "description": "科室名称，如 '中医科'、'针灸科'"
          },
          "date": {
            "type": "string",
            "description": "预约日期，格式 YYYY-MM-DD 或 '今天'/'明天'/'后天'"
          },
          "patientName": { "type": "string", "description": "患者姓名（可选）" },
          "preferredDoctor": { "type": "string", "description": "指定医生姓名（可选）" },
          "timeSlot": {
            "type": "string",
            "enum": ["morning", "afternoon", "any"],
            "default": "morning"
          }
        }
      }
    },
    {
      "name": "add_medication_reminder",
      "description": "在用户系统日历中添加服药提醒事件。",
      "riskLevel": "MEDIUM",
      "requiresConfirmation": true,
      "parameters": {
        "type": "object",
        "required": ["medicineName"],
        "properties": {
          "medicineName": { "type": "string", "description": "药品名称" },
          "dosage": { "type": "string", "description": "用量说明" },
          "frequency": { "type": "string", "default": "每日三次" },
          "times": { "type": "array", "items": { "type": "string" }, "default": ["08:00", "12:00", "18:00"] },
          "startDate": { "type": "string", "description": "开始日期 YYYY-MM-DD" },
          "durationDays": { "type": "number", "default": 7 },
          "notes": { "type": "string" }
        }
      }
    },
    {
      "name": "save_prescription",
      "description": "将处方内容保存到用户本地文件。",
      "riskLevel": "MEDIUM",
      "requiresConfirmation": true,
      "parameters": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string", "description": "处方内容" },
          "format": { "type": "string", "enum": ["pdf", "txt", "png"], "default": "pdf" },
          "filename": { "type": "string" }
        }
      }
    },
    {
      "name": "capture_tongue_image",
      "description": "调用摄像头拍摄舌象照片，用于 AI 舌诊分析。",
      "riskLevel": "MEDIUM",
      "requiresConfirmation": true,
      "parameters": {
        "type": "object",
        "properties": {
          "resolution": { "type": "string", "default": "1280x720" },
          "guidanceEnabled": { "type": "boolean", "default": true }
        }
      }
    }
  ],
  
  "config": {
    "defaultHospitalUrl": { "type": "string", "default": "https://www.cs4hospital.cn/" },
    "browserVisible": { "type": "boolean", "default": true },
    "calendarApp": { "type": "string", "enum": ["system", "google", "outlook"], "default": "system" }
  }
}
